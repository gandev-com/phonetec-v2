---
const brands = ['Samsung', 'Apple', 'Xiaomi', 'Huawei', 'BQ', 'LG', 'Sony', 'OnePlus'];
---

<div class="grid grid-cols-2 gap-4 sm:grid-cols-4 lg:grid-cols-8">
  {brands.map((brand) => (
    <div class="rounded-2xl border border-gray-200 bg-white px-4 py-5 text-center text-sm font-semibold text-gray-700 shadow-sm transition-transform duration-300 hover:-translate-y-1">
      {brand}
    </div>
  ))}
</div>