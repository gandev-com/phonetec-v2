---
import {
  siApple,
  siHuawei,
  siLg,
  siOneplus,
  siSamsung,
  siSony,
  siXiaomi,
  type SimpleIcon,
} from 'simple-icons';

type Brand = {
  name: string;
  icon?: SimpleIcon;
};

const brands: Brand[] = [
  { name: 'Samsung', icon: siSamsung },
  { name: 'Apple', icon: siApple },
  { name: 'Xiaomi', icon: siXiaomi },
  { name: 'Huawei', icon: siHuawei },
  { name: 'BQ' },
  { name: 'LG', icon: siLg },
  { name: 'Sony', icon: siSony },
  { name: 'OnePlus', icon: siOneplus },
];
---

<div class="grid grid-cols-2 gap-4 sm:grid-cols-4 lg:grid-cols-8">
  {brands.map((brand) => (
    <div class="rounded-2xl border border-gray-200 bg-white px-4 py-5 text-center shadow-sm transition-transform duration-300 hover:-translate-y-1">
      <div class="flex min-h-12 items-center justify-center">
        {brand.icon ? (
          <svg
            viewBox="0 0 24 24"
            class="h-8 w-8"
            fill={`#${brand.icon.hex}`}
            aria-hidden="true"
            set:html={`<path d="${brand.icon.path}" />`}
          ></svg>
        ) : (
          <span class="text-base font-extrabold tracking-wide text-gray-700">{brand.name}</span>
        )}
      </div>
      <p class="mt-3 text-sm font-semibold text-gray-700">{brand.name}</p>
    </div>
  ))}
</div>