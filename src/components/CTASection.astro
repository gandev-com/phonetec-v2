---
interface Props {
  title: string;
  text: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  title,
  text,
  primaryHref = 'tel:+34636573031',
  primaryLabel = 'Llamar ahora',
  secondaryHref = 'https://api.whatsapp.com/send?phone=34636573031&text=Presupuesto',
  secondaryLabel = 'Hablar por WhatsApp',
} = Astro.props;
---

<section class="section-space">
  <div class="container-shell">
    <div class="overflow-hidden rounded-[2rem] bg-gradient-to-r from-phonetec to-blue-800 px-6 py-12 text-white shadow-2xl shadow-blue-900/20 sm:px-10 lg:px-14" data-reveal>
      <div class="grid gap-8 lg:grid-cols-[1fr_auto] lg:items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-100">Atención rápida</p>
          <h2 class="mt-4 text-3xl font-extrabold sm:text-4xl">{title}</h2>
          <p class="mt-4 max-w-2xl text-base leading-8 text-blue-100 sm:text-lg">{text}</p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row lg:flex-col">
          <a href={primaryHref} class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-phonetec transition-all duration-300 hover:-translate-y-0.5 hover:bg-blue-50">{primaryLabel}</a>
          <a href={secondaryHref} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-full border border-white/25 px-6 py-3 text-sm font-semibold text-white transition-all duration-300 hover:-translate-y-0.5 hover:bg-white/10">{secondaryLabel}</a>
        </div>
      </div>
    </div>
  </div>
</section>