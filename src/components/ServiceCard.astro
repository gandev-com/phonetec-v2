---
interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<article class="group rounded-3xl border border-gray-100 bg-white p-6 shadow-md shadow-slate-200/60 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl" data-reveal>
  <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-blue-50 text-phonetec transition-transform duration-300 group-hover:scale-110 group-hover:rotate-3">
    <span set:html={icon}></span>
  </div>
  <h3 class="mt-5 text-xl font-bold text-gray-900">{title}</h3>
  <p class="mt-3 text-sm leading-7 text-gray-600">{description}</p>
</article>