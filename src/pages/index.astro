---
import Layout from '../components/Layout.astro';
import Hero from '../components/Hero.astro';
import FeatureCard from '../components/FeatureCard.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ReviewsCarousel from '../components/ReviewsCarousel.astro';
import BrandLogos from '../components/BrandLogos.astro';
import ContactForm from '../components/ContactForm.astro';
import CTASection from '../components/CTASection.astro';
import StatsStrip from '../components/StatsStrip.astro';
import ServiceAdvisor from '../components/ServiceAdvisor.astro';

const serviceIcons = {
  screen: '<svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="5" y="3" width="14" height="18" rx="2"></rect><path d="M9 17h6"></path></svg>',
  battery: '<svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="7" width="16" height="10" rx="2"></rect><path d="M21 10v4"></path><path d="M8 10l-2 2h3l-2 2"></path></svg>',
  software: '<svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M8 3H5a2 2 0 0 0-2 2v3"></path><path d="M16 3h3a2 2 0 0 1 2 2v3"></path><path d="M16 21h3a2 2 0 0 0 2-2v-3"></path><path d="M8 21H5a2 2 0 0 1-2-2v-3"></path><path d="M10 9.5 8 12l2 2.5"></path><path d="m14 9.5 2 2.5-2 2.5"></path></svg>',
  board: '<svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="7" y="7" width="10" height="10" rx="2"></rect><path d="M4 10h3M4 14h3M17 4v3M12 4v3M20 10h-3M20 14h-3M12 17v3M17 17v3"></path></svg>',
  data: '<svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8"><ellipse cx="12" cy="5" rx="7" ry="3"></ellipse><path d="M5 5v6c0 1.7 3.1 3 7 3s7-1.3 7-3V5"></path><path d="M5 11v6c0 1.7 3.1 3 7 3s7-1.3 7-3v-6"></path></svg>',
  charging: '<svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M10 7V5a2 2 0 0 1 4 0v2"></path><rect x="7" y="7" width="10" height="12" rx="2"></rect><path d="m11 12 2-2v4l2-2"></path></svg>',
  virus: '<svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v3M12 19v3M4.9 4.9l2.1 2.1M17 17l2.1 2.1M2 12h3M19 12h3M4.9 19.1 7 17M17 7l2.1-2.1"></path></svg>',
  water: '<svg viewBox="0 0 24 24" class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3s5 5.2 5 9a5 5 0 0 1-10 0c0-3.8 5-9 5-9Z"></path><path d="M9 15c.6.8 1.6 1.3 3 1.3"></path></svg>',
};

const services = [
  ['Reparación de Pantallas', 'Sustitución de pantallas rotas, táctiles y paneles OLED con acabados de alta precisión.', serviceIcons.screen],
  ['Cambio de Batería', 'Baterías nuevas para recuperar autonomía, carga estable y un uso diario fiable.', serviceIcons.battery],
  ['Reparación de Software', 'Solucionamos bloqueos, fallos de sistema, actualizaciones y problemas de rendimiento.', serviceIcons.software],
  ['Reparación en Placa', 'Diagnóstico técnico y microelectrónica para fallos complejos en placa base.', serviceIcons.board],
  ['Recuperación de Datos', 'Rescate de información en dispositivos dañados, bloqueados o con errores críticos.', serviceIcons.data],
  ['Cambio de Conector de Carga', 'Reparación o sustitución de puertos de carga, USB-C, Lightning y conectores dañados.', serviceIcons.charging],
  ['Eliminación de Virus y Malware', 'Limpieza profunda del sistema, eliminación de amenazas y optimización completa.', serviceIcons.virus],
  ['Daños por agua / Móviles mojados', 'Tratamiento técnico ante corrosión y humedad para maximizar la recuperación.', serviceIcons.water],
];
---

<Layout
  title="PHONETEC | Reparación de móviles, tablets y ordenadores en Alcalá de Henares"
  description="Servicio técnico PHONETEC en Alcalá de Henares: reparación de móviles, tablets, portátiles, ordenadores y apoyo en desarrollo web con Gandev, con repuestos originales, garantía y atención rápida."
>
  <Hero
    title="Reparación de Móviles, Tablets y Ordenadores en Alcalá de Henares"
    subtitle="Todos nuestros repuestos son ORIGINALES y con GARANTÍA. Diagnóstico técnico, reparación rápida y soporte profesional para tus dispositivos electrónicos."
  />

  <StatsStrip />

  <section class="section-space">
    <div class="container-shell">
      <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
        <div data-reveal="left">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-phonetec">Haz tus reparaciones con nosotros</p>
          <h2 class="section-title mt-4">Servicio técnico cercano, profesional y preparado para cualquier avería</h2>
          <p class="section-copy">
            En PHONETEC trabajamos con móviles, tablets y ordenadores de marcas como Samsung, Xiaomi, Apple, Huawei o BQ. Apostamos por repuestos originales, procesos claros y una atención directa para que sepas qué se va a reparar y cuánto tardará.
          </p>
          <div class="mt-8 flex flex-col gap-4 sm:flex-row">
            <a href="#reviews" class="btn-secondary">Ver reseñas</a>
            <a href="https://api.whatsapp.com/send?phone=34636573031&text=Presupuesto" target="_blank" rel="noopener noreferrer" class="btn-primary">Pedir presupuesto</a>
          </div>
        </div>

        <div class="grid gap-5 sm:grid-cols-2">
          <div class="glass-panel p-6 sm:col-span-2" data-reveal="right">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-phonetec">PHONETEC</p>
            <p class="mt-4 text-lg font-semibold leading-8 text-gray-800">
              Atención local en Alcalá de Henares, explicaciones claras, garantía real y seguimiento durante todo el proceso de reparación.
            </p>
          </div>
          <div class="rounded-3xl bg-blue-50 p-6" data-reveal data-stagger="1">
            <p class="text-4xl font-extrabold text-phonetec">6 meses</p>
            <p class="mt-2 text-sm text-gray-600">de garantía en todas las reparaciones</p>
          </div>
          <div class="rounded-3xl bg-orange-50 p-6" data-reveal data-stagger="2">
            <p class="text-4xl font-extrabold text-accent">100%</p>
            <p class="mt-2 text-sm text-gray-600">repuestos originales o equivalentes de máxima calidad</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section-space bg-mesh">
    <div class="container-shell">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-phonetec">¿Qué ofrecemos?</p>
      <h2 class="section-title mt-4">Un servicio técnico pensado para resolver rápido y bien</h2>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        <FeatureCard eyebrow="Rapidez" title="Reparación rápida y eficaz" description="Optimizamos el diagnóstico y la intervención para reducir tiempos y que recuperes tu dispositivo cuanto antes." />
        <FeatureCard eyebrow="Garantía" title="6 meses de garantía en toda reparación" description="Respaldamos cada trabajo con garantía para que tengas seguridad después de la entrega." />
        <FeatureCard eyebrow="Repuestos" title="Usamos solo repuestos 100% originales" description="Priorizamos componentes originales y soluciones duraderas que mantengan el rendimiento del equipo." />
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="container-shell">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-phonetec">Servicios que reparamos</p>
      <h2 class="section-title mt-4">¿Qué Reparamos?</h2>
      <p class="section-copy">Desde pantallas y baterías hasta averías complejas en placa o recuperación de datos. Cubrimos las incidencias más frecuentes de móviles, tablets, portátiles y PC.</p>
      <div class="mt-10 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        {services.map(([title, description, icon]) => (
          <ServiceCard title={title} description={description} icon={icon} />
        ))}
      </div>
    </div>
  </section>

  <ServiceAdvisor />

  <section id="reviews" class="section-space bg-gray-50">
    <div class="container-shell">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-phonetec">Clientes satisfechos</p>
      <h2 class="section-title mt-4">¿Qué opinan nuestros clientes?</h2>
      <p class="section-copy">Trabajamos para que cada reparación se traduzca en confianza, transparencia y un dispositivo listo para volver a funcionar.</p>
      <div class="mt-10">
        <ReviewsCarousel />
      </div>
    </div>
  </section>

  <section class="section-space">
    <div class="container-shell">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-phonetec">Marcas que reparamos</p>
      <h2 class="section-title mt-4">Trabajamos con las marcas más habituales del mercado</h2>
      <p class="section-copy">Samsung, Apple, Xiaomi, Huawei, BQ y otras marcas con piezas compatibles, experiencia de reparación y procesos seguros.</p>
      <div class="mt-10">
        <BrandLogos />
      </div>
    </div>
  </section>

  <section id="desarrollo-web" class="section-space scroll-mt-28">
    <div class="container-shell">
      <div class="grid gap-8 rounded-[2rem] bg-slate-950 px-6 py-10 text-white shadow-2xl shadow-slate-900/20 lg:grid-cols-[0.9fr_1.1fr] lg:items-center sm:px-10" data-reveal>
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-blue-300">Servicio adicional</p>
          <h2 class="mt-4 text-3xl font-extrabold sm:text-4xl">Desarrollo web para negocios con Gandev</h2>
          <p class="mt-4 text-base leading-8 text-slate-300 sm:text-lg">
            Si además de reparar tus dispositivos necesitas una web moderna para tu empresa, trabajamos con Gandev para ofrecer diseño, desarrollo y optimización de sitios profesionales orientados a captar clientes.
          </p>
        </div>
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-3xl border border-white/10 bg-white/5 p-6" data-reveal data-stagger="1">
            <h3 class="text-xl font-bold">Web corporativa</h3>
            <p class="mt-3 text-sm leading-7 text-slate-300">Presencia digital clara, rápida y alineada con la imagen del negocio.</p>
          </div>
          <div class="rounded-3xl border border-white/10 bg-white/5 p-6" data-reveal data-stagger="2">
            <h3 class="text-xl font-bold">SEO técnico</h3>
            <p class="mt-3 text-sm leading-7 text-slate-300">Arquitectura, rendimiento y estructura pensadas para posicionar mejor.</p>
          </div>
          <div class="rounded-3xl border border-white/10 bg-white/5 p-6 sm:col-span-2" data-reveal data-stagger="3">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <h3 class="text-xl font-bold">Solicita una propuesta digital</h3>
                <p class="mt-2 text-sm leading-7 text-slate-300">Accede a gandev.es o usa el formulario para indicar que necesitas desarrollo web.</p>
              </div>
              <a href="https://gandev.es" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-sm font-semibold text-phonetec transition-all duration-300 hover:-translate-y-0.5 hover:bg-blue-50">Ir a Gandev.es</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection
    title="¿Necesitas presupuesto rápido para tu reparación?"
    text="Explícanos la avería o indícanos si necesitas una nueva web para tu negocio y te orientamos con la mejor solución desde Alcalá de Henares."
    primaryLabel="Llamar ahora"
    secondaryLabel="Pedir presupuesto por WhatsApp"
  />

  <section class="section-space pt-0">
    <div class="container-shell">
      <ContactForm />
    </div>
  </section>
</Layout>